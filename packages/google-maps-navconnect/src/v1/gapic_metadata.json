{
  "schema": "1.0",
  "comment": "This file maps proto services/RPCs to the corresponding library clients/methods",
  "language": "typescript",
  "protoPackage": "google.maps.navconnect.v1",
  "libraryPackage": "@google-cloud/navconnect",
  "services": {
    "NavConnectService": {
      "clients": {
        "grpc": {
          "libraryClient": "NavConnectServiceClient",
          "rpcs": {
            "CreateTrip": {
              "methods": [
                "createTrip"
              ]
            },
            "GetTrip": {
              "methods": [
                "getTrip"
              ]
            }
          }
        },
        "grpc-fallback": {
          "libraryClient": "NavConnectServiceClient",
          "rpcs": {
            "CreateTrip": {
              "methods": [
                "createTrip"
              ]
            },
            "GetTrip": {
              "methods": [
                "getTrip"
              ]
            }
          }
        }
      }
    }
  }
}
